rules_version = '2';

// ============================================================================
// Pirates Tools — Règles de sécurité Firestore (S1)
// ============================================================================
//
// MODÈLE DE CONFIANCE
//   • Le SDK client (navigateur) est SOUMIS à ces règles.
//   • L'Admin SDK serveur (api/_lib/firebase.js, webhook) les CONTOURNE
//     totalement — c'est lui, et lui seul, qui écrit les données autoritaires
//     (statut 'paid', journal des paiements, idempotence, overrides catalogue).
//
// PRINCIPE : DEFAULT-DENY. Toute collection non couverte par un `match`
// explicite ci-dessous est refusée en lecture ET écriture (règle finale
// catch-all). On n'ouvre QUE ce qui est strictement nécessaire au client.
//
// Déploiement : `firebase deploy --only firestore:rules`
// Test : `firebase emulators:exec --only firestore "node scripts/test-rules.js"`
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ---- users/{uid} : profil client, self-only ---------------------------
    // Un utilisateur ne peut lire/écrire QUE son propre document. Les champs
    // sont restreints à une allowlist (anti mass-assignment) : impossible
    // d'injecter un champ arbitraire (ex. un rôle, un privilège). Le champ
    // `loyalty` reste toléré mais est INERTE côté sécurité — la remise réelle
    // est calculée serveur depuis la collection `payments/` (webhook-only),
    // jamais depuis ce champ.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(
             ['name', 'email', 'phone', 'address', 'avatar', 'loyalty', 'createdAt']);
      // Droit à l'oubli (M4) : le titulaire peut supprimer SON propre profil
      // (flux « supprimer mon compte » : purge orders + profil + Auth). Le
      // journal comptable payments/ (server-only) reste conservé au titre des
      // obligations légales de conservation.
      allow delete: if isOwner(userId);

      // ---- users/{uid}/orders : commandes du client -----------------------
      // Le client peut CRÉER ses propres lignes de commande, mais UNIQUEMENT
      // avec un statut non-payé ('quote' = devis WhatsApp, 'pending' =
      // paiement initié, 'declared' = crypto déclaré à vérifier). Il ne peut
      // JAMAIS écrire 'paid' ni les tampons serveur (confirmedByWebhook,
      // paidAt…) : seul le webhook (Admin SDK) confirme un paiement. Il ne
      // peut ni modifier ni supprimer une commande existante.
      //
      // NOTE canal crypto DÉSACTIVÉ (16/07/2026) : 'declared' (commande crypto
      // annoncée par le client, à vérifier à la main) est RETIRÉ de la liste
      // blanche → même en forçant le SDK, personne ne peut fabriquer une
      // commande crypto. RÉACTIVER = remettre 'declared' ci-dessous ET
      // PT_CRYPTO_ENABLED=true dans app.js.
      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.status in ['quote', 'pending']
          && !request.resource.data.keys().hasAny(
               ['confirmedByWebhook', 'paidAt', 'stripePaymentIntent'])
          && request.resource.data.keys().hasOnly(
               ['date', 'items', 'lines', 'total', 'status',
                'method', 'paymentIntentId', 'stripeSessionId'])
          && (!('total' in request.resource.data) || request.resource.data.total is number)
          && (!('items' in request.resource.data) || request.resource.data.items is number);
        // Confirmation/mise à jour = Admin SDK serveur uniquement.
        allow update: if false;
        // Suppression : le titulaire peut effacer ses propres commandes
        // (droit à l'oubli — M4).
        allow delete: if isOwner(userId);
      }
    }

    // ---- Collections SERVEUR UNIQUEMENT (Admin SDK, contourne les règles) --
    // Aucune de ces collections n'est jamais lue ni écrite par le client.
    // Les fermer explicitement documente l'intention (et double le catch-all).
    match /payments/{paymentId}        { allow read, write: if false; } // journal paiements (email/CP/montants)
    match /stripe_events/{eventId}     { allow read, write: if false; } // idempotence webhook
    match /rate_limits/{bucketId}      { allow read, write: if false; } // compteurs anti-abus (IP)
    match /product_overrides/{prodId}  { allow read, write: if false; } // prix/stock admin

    // Mesure d'audience maison : écrite par l'Admin SDK (api/events.js), lue
    // UNIQUEMENT par l'API admin authentifiée (api/admin?type=stats). Jamais
    // par le client → fermé ici (double le catch-all, documente l'intention).
    // analytics_visitors contient le profil d'affinité des visiteurs CONSENTIS
    // (pseudonyme), effaçable au titre du droit à l'oubli.
    match /analytics_daily/{day}         { allow read, write: if false; }
    match /analytics_products/{prodId}   { allow read, write: if false; }
    match /analytics_clicks/{targetId}   { allow read, write: if false; }
    match /analytics_geo/{country}       { allow read, write: if false; }
    match /analytics_visitors/{visitorId}{ allow read, write: if false; }
    match /analytics_events_recent/{id}  { allow read, write: if false; }

    // ---- DEFAULT-DENY final : tout le reste est refusé --------------------
    // Une requête n'est autorisée que si AU MOINS une règle ci-dessus l'accorde.
    // Ce catch-all ne peut donc pas rouvrir un accès ; il verrouille toute
    // collection future oubliée. À NE PAS retirer.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
